#Get lambda function name from parent folder name
FUNCTION_NAME=$(basename "$(pwd -W 2>/dev/null || pwd)")

#Clear previous zip if there is one (there shouldn't be)
rm -f function.zip

#Help
print_help() {
	cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Options:
  -u, --upload-only    Upload only
  -i, --invoke-only    Invoke only
  -h, --help           Help - shows this help message
EOF
}

#Check for arguments
UPLOAD_ONLY=0
INVOKE_ONLY=0

for arg in "$@"; do
	case $arg in
		-u|--upload-only)
			UPLOAD_ONLY=1
			shift
			;;
		-i|--invoke-only)
			INVOKE_ONLY=1
			shift
			;;
		-h|--help)
			print_help
			exit 0
			shift
			;;
		*)
			echo "Unknown option: $arg"
			print_help
			exit 1
			;;
	esac
done

#Conflicting flags warning
if [ "$UPLOAD_ONLY" -eq 1 ] && [ "$INVOKE_ONLY" -eq 1 ]; then
	echo "Using --upload-only and --invoke-only together has the same effect as using neither flag."
fi

#Only zip and upload if NOT INVOKE_ONLY
if [ "$INVOKE_ONLY" -eq 0 ]; then
	#Zip
	echo -n -e "Zipping $FUNCTION_NAME..."
	zip -r -q function.zip .
	echo -n -e "\r\033[K" #Wipe the previous line
	
	#Upload
	echo -n -e "Uploading $FUNCTION_NAME..."
	aws lambda update-function-code --function-name "$FUNCTION_NAME" --zip-file fileb://function.zip > /dev/null
	echo -n -e "\r\033[K" #Wipe the previous line
	
	#Wait until AWS confirms the new code is live
	echo -n -e "Waiting for $FUNCTION_NAME to be updated on AWS..."
	aws lambda wait function-updated --function-name "$FUNCTION_NAME"
	echo -n -e "\r\033[K" #Wipe the previous line
	#sleep 0.2 #Give a moment for AWS to update the code
fi

#Invoke and log (with colouring)
#(Exit here if UPLOAD_ONLY and not INVOKE_ONLY)
if [ "$UPLOAD_ONLY" -eq 1 ] && [ "$INVOKE_ONLY" -eq 0 ]; then
	echo "Upload complete (skipped invoke)"
	rm -f function.zip
	exit 0
fi

aws lambda invoke \
	--function-name "$FUNCTION_NAME" \
	--log-type Tail \
	response.json \
	--query 'LogResult' \
	--output text | base64 --decode 2>/dev/null | awk '
BEGIN {
	in_error=0
}

{
	#Remove prefix: timestamp + container 
	gsub(/^[0-9T:\.\+\-]+ [0-9\/]+\[\$LATEST\][a-f0-9]+ /, "", $0)

	#Remove request IDs (this also removes UUIDs...)
	#gsub(/[a-f0-9\-]{36}/, "", $0)

	#Skip excess start and end lines
	if ($0 ~ /^(INIT_START|START RequestId|END RequestId)/) next
}

#Colour errors
/ERROR/ {
	in_error=1
	print "\033[31m" $0 "\033[0m"
	next
}

/^[[:space:]]+at / {
	if (in_error) {
		print "\033[31m" $0 "\033[0m"
		next
	}
}

#Stop error block when normal log resumes
/INFO|WARN/ {
	in_error=0
}

#Colour other levels
/INFO/ {print "\033[36m" $0 "\033[0m"; next}
/WARN/ {print "\033[33m" $0 "\033[0m"; next}

#Exit
/REPORT RequestId:/ {
	print;
	exit
}

#Print
{print}
'

#Lambda response, pretty-printed
#If .body is JSON string, try to parse it. If parsing fails, print raw .body
#Else, .body is already object, so print it as it already is
jq -r '
	.body = (
		if (.body | type) == "string"
		then (try (.body | fromjson) catch .body)
		else .body
		end
	)
' response.json

rm -f function.zip
rm -f response.json